# 1. Use a lightweight Python image
FROM python:3.10-slim

# 2. Set the working directory inside the container
WORKDIR /app

# 3. Copy your project files into the container
COPY . /app

# 4. Install system dependencies (needed for subprocess calls)
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 5. Install Python dependencies
# Ensure your requirements.txt includes: openenv-core, openai, pandas, scikit-learn
RUN pip install --no-cache-dir -r requirements.txt

# 6. Expose the port (Hugging Face Spaces usually use 7860)
EXPOSE 7860

# 7. Command to run your baseline script
# This ensures the [START], [STEP], [END] logs appear immediately
CMD ["python", "inference.py"]